---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Bli medlem / አባል ይሁኑ — Abune Tekle Haymanot">
  <Fragment slot="back-link">
    <a href="/" class="back-link">← Tillbaka / ← ተመለስ</a>
  </Fragment>

  <Fragment slot="head">
    <style>
      .form-card { background: var(--card, #fff); border: 1px solid var(--border, #e5e5e5); border-radius: 14px; padding: 24px 20px; margin-bottom: 16px; }
      .form-card h1 { font-size: 22px; margin: 0 0 4px; }
      .form-card .subtitle { font-size: 14px; color: var(--muted, #666); margin-bottom: 20px; }
      .form-group { margin-bottom: 16px; }
      .form-group label { display: block; font-size: 14px; font-weight: 600; margin-bottom: 4px; }
      .form-group .label-am { font-weight: 400; color: var(--muted, #666); font-size: 13px; }
      .form-group input[type="text"], .form-group input[type="email"], .form-group input[type="tel"] { width: 100%; padding: 12px; border: 1px solid var(--border, #e5e5e5); border-radius: 10px; font-size: 16px; background: var(--bg, #faf9f6); color: var(--fg, #222); }
      .form-group input:focus { outline: 2px solid var(--accent, #3b5bdb); border-color: var(--accent, #3b5bdb); }
      .membership-type { display: flex; gap: 10px; margin-bottom: 16px; }
      .type-btn { flex: 1; padding: 16px 12px; border: 3px solid var(--border, #e5e5e5); border-radius: 12px; background: transparent; cursor: pointer; text-align: center; font-size: 14px; color: var(--fg, #222); }
      .type-btn.selected { border-color: var(--accent, #3b5bdb); background: #f0f4ff; }
      .type-btn .price { display: block; font-size: 24px; font-weight: 700; color: var(--accent, #3b5bdb); margin-bottom: 4px; }
      .family-section { display: none; border: 1px solid var(--border, #e5e5e5); border-radius: 10px; padding: 16px; margin-bottom: 16px; background: #f9fafb; }
      .family-section.visible { display: block; }
      .family-member-row { display: grid; grid-template-columns: 1fr 1fr auto; gap: 8px; margin-bottom: 8px; align-items: end; }
      .family-member-row input, .family-member-row select { width: 100%; padding: 10px; border: 1px solid var(--border, #e5e5e5); border-radius: 8px; font-size: 14px; background: var(--bg, #faf9f6); color: var(--fg, #222); }
      .add-family-btn { padding: 10px; border: 1px dashed var(--accent, #3b5bdb); border-radius: 8px; background: transparent; color: var(--accent, #3b5bdb); cursor: pointer; width: 100%; font-size: 14px; }
      .fee-summary { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 10px; padding: 14px; margin-bottom: 16px; text-align: center; font-size: 15px; }
      .fee-summary .fee-amount { font-size: 28px; font-weight: 700; color: #16a34a; }
      .gdpr-box { background: #f0f4ff; border: 1px solid #d0d8f0; border-radius: 10px; padding: 16px; margin-bottom: 16px; font-size: 13px; line-height: 1.6; }
      .consent-btn { display: flex; align-items: center; gap: 14px; margin-top: 16px; padding: 16px; border: 3px solid #ccc; border-radius: 12px; cursor: pointer; background: #f9f9f9; width: 100%; text-align: left; font-size: 16px; font-weight: 600; color: #222; }
      .consent-btn.checked { border-color: #22c55e; background: #f0fdf4; }
      .consent-box { width: 28px; height: 28px; min-width: 28px; border: 3px solid #999; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 20px; background: #fff; flex-shrink: 0; }
      .consent-btn.checked .consent-box { background: #22c55e; border-color: #22c55e; color: #fff; }
      .submit-btn { display: block; width: 100%; padding: 16px; border: none; border-radius: 12px; background: var(--accent, #3b5bdb); color: white; font-size: 18px; font-weight: 700; cursor: pointer; margin-top: 8px; }
      .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }
      .success-msg { display: none; text-align: center; padding: 32px 16px; }
      .success-msg h2 { margin-bottom: 8px; color: #2b8a3e; }
      .error-msg { display: none; color: #c92a2a; text-align: center; padding: 12px; font-size: 14px; }
      .swish-btn { display: inline-block; padding: 14px 28px; background: #5bbf2e; color: #fff; border-radius: 10px; text-decoration: none; font-weight: 700; margin-top: 8px; }
    </style>
  </Fragment>

  <div class="form-card" id="intake-form-card">
    <h1>Bli medlem <span style="font-size:18px;color:var(--muted,#666)">/ አባል ይሁኑ</span></h1>
    <p class="subtitle">
      Fyll i formuläret nedan. Vi kontaktar dig inom några dagar.<br />
      ከዚህ በታች ያለውን ቅጽ ይሙሉ። በጥቂት ቀናት ውስጥ እናገኝዎታለን።
    </p>

    <form id="intake-form" novalidate>
      <input type="hidden" id="field-source" value="wifi" />
      <input type="hidden" id="field-church-id" value="nacka" />
      <input type="hidden" id="field-membership-type" value="individual" />
      <input type="hidden" id="field-monthly-fee" value="200" />

      <div class="membership-type">
        <button type="button" class="type-btn selected" id="type-individual" data-type="individual">
          <span class="price" id="price-individual">200 kr</span>
          <span>Enskild / ግለሰብ</span>
          <span style="font-size:11px;color:var(--muted,#666)">per månad</span>
        </button>
        <button type="button" class="type-btn" id="type-family" data-type="family">
          <span class="price" id="price-family">500 kr</span>
          <span>Familj / ቤተሰብ</span>
          <span style="font-size:11px;color:var(--muted,#666)">per månad</span>
        </button>
      </div>

      <div class="form-group">
        <label>Förnamn <span class="label-am">/ ስም</span></label>
        <input type="text" id="field-first-name" required autocomplete="given-name" />
      </div>
      <div class="form-group">
        <label>Efternamn <span class="label-am">/ የአባት ስም</span></label>
        <input type="text" id="field-last-name" required autocomplete="family-name" />
      </div>
      <div class="form-group">
        <label>Telefon <span class="label-am">/ ስልክ</span></label>
        <input type="tel" id="field-phone" required autocomplete="tel" />
      </div>
      <div class="form-group">
        <label>E-post <span class="label-am">/ ኢሜይል</span></label>
        <input type="email" id="field-email" autocomplete="email" />
      </div>
      <div class="form-group">
        <label>Personnummer <span class="label-am">/ የግል ቁጥር</span></label>
        <input type="text" id="field-personal-number" placeholder="YYYYMMDD-XXXX" autocomplete="off" />
      </div>

      <div class="family-section" id="family-section">
        <strong>Familjemedlemmar / የቤተሰብ አባላት</strong>
        <p style="font-size:12px;color:var(--muted,#666);margin:4px 0 12px">Maka/make + barn under 18 år.</p>
        <div id="family-members-list"></div>
        <button type="button" class="add-family-btn" id="add-family-btn">+ Lägg till / + ጨምር</button>
      </div>

      <div class="fee-summary">
        Månadsavgift / ወርሃዊ ክፍያ: <span class="fee-amount" id="fee-display">200 kr</span>
        <div style="font-size:12px;color:var(--muted,#666);margin-top:4px">Dras via autogiro efter första betalningen</div>
      </div>

      <div class="gdpr-box">
        <div><strong>GDPR-samtycke:</strong> Genom att skicka detta formulär samtycker du till att Abune Tekle Haymanot Etiopiska Ortodoxa Tewahedo Kyrkan lagrar dina personuppgifter i enlighet med GDPR.</div>
        <div style="color:var(--muted,#666);margin-top:8px"><strong>GDPR ፈቃድ:</strong> ይህንን ቅጽ በመላክ የግል መረጃዎን በ GDPR መሰረት እንዲያከማች ይስማማሉ።</div>
        <input type="hidden" id="field-gdpr-consent" value="" />
        <button type="button" class="consent-btn" id="consent-btn">
          <span class="consent-box" id="consent-box"></span>
          <span>Jag samtycker / እስማማለሁ</span>
        </button>
      </div>

      <div class="error-msg" id="error-msg"></div>
      <button type="submit" class="submit-btn" id="submit-btn">Skicka ansökan / ማመልከቻ ላክ</button>
    </form>
  </div>

  <div class="form-card success-msg" id="success-msg">
    <h2>Tack! Din ansökan behandlas.</h2>
    <p style="color:var(--muted,#666)">አመሰግናለሁ! ማመልከቻዎ በሂደት ላይ ነው።</p>
    <div id="payment-step" style="margin-top:16px;padding:16px;background:#f0f4ff;border-radius:10px;text-align:left;font-size:14px;">
      <strong>Nästa steg — första betalningen:</strong>
      <p style="margin:8px 0">Swisha <strong id="success-fee">200 kr</strong> för att aktivera ditt medlemskap.</p>
      <a id="success-swish-link" class="swish-btn" href="#">Swish — betala nu</a>
      <div id="autogiro-step" style="display:none;margin-top:16px;padding-top:12px;border-top:1px solid #d0d8f0;">
        <strong>Steg 2 — Autogiro:</strong>
        <p style="margin:6px 0">Signera med BankID så dras avgiften automatiskt varje månad.</p>
        <a id="autogiro-link" class="swish-btn" href="#" target="_blank" style="background:var(--accent,#3b5bdb)">Starta autogiro (BankID)</a>
      </div>
    </div>
    <br />
    <a href="/" class="back-link">← Tillbaka till startsidan / ወደ መነሻ ገጽ ተመለስ</a>
  </div>
</BaseLayout>

<script>
  const API_URL = 'https://membership-intake-479770870521.europe-north1.run.app/intake';

  let churchConfig: any = {};
  let familyCount = 0;

  fetch('/content.json', { credentials: 'omit', cache: 'no-store' })
    .then(r => r.ok ? r.json() : {})
    .then(data => {
      churchConfig = data?.church || {};
      const indFee = churchConfig.membership_fee_individual || 200;
      const famFee = churchConfig.membership_fee_family || 500;
      document.getElementById('price-individual')!.textContent = indFee + ' kr';
      document.getElementById('price-family')!.textContent = famFee + ' kr';
      document.getElementById('field-monthly-fee')!.setAttribute('value', String(indFee));
      document.getElementById('fee-display')!.textContent = indFee + ' kr';
    })
    .catch(() => {});

  const params = new URLSearchParams(window.location.search);
  if (params.get('source')) (document.getElementById('field-source') as HTMLInputElement).value = params.get('source')!;
  if (params.get('church')) (document.getElementById('field-church-id') as HTMLInputElement).value = params.get('church')!;

  // Membership type
  document.querySelectorAll('.type-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.getAttribute('data-type')!;
      document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      const indFee = churchConfig.membership_fee_individual || 200;
      const famFee = churchConfig.membership_fee_family || 500;
      const fee = type === 'family' ? famFee : indFee;
      (document.getElementById('field-membership-type') as HTMLInputElement).value = type;
      (document.getElementById('field-monthly-fee') as HTMLInputElement).value = String(fee);
      document.getElementById('fee-display')!.textContent = fee + ' kr';
      const famSection = document.getElementById('family-section')!;
      if (type === 'family') {
        famSection.classList.add('visible');
        if (familyCount === 0) addFamilyMember();
      } else {
        famSection.classList.remove('visible');
      }
    });
  });

  // Family members
  document.getElementById('add-family-btn')!.addEventListener('click', addFamilyMember);

  function addFamilyMember() {
    if (familyCount >= 4) return;
    familyCount++;
    const list = document.getElementById('family-members-list')!;
    const row = document.createElement('div');
    row.className = 'family-member-row';
    row.innerHTML = '<input type="text" placeholder="Förnamn / ስም" data-field="first_name" />' +
      '<input type="text" placeholder="Efternamn / የአባት ስም" data-field="last_name" />' +
      '<select data-field="relation"><option value="spouse">Maka/Make</option><option value="child">Barn</option></select>';
    list.appendChild(row);
  }

  // Consent
  document.getElementById('consent-btn')!.addEventListener('click', () => {
    const input = document.getElementById('field-gdpr-consent') as HTMLInputElement;
    const btn = document.getElementById('consent-btn')!;
    const box = document.getElementById('consent-box')!;
    if (input.value === 'true') {
      input.value = ''; btn.classList.remove('checked'); box.textContent = '';
    } else {
      input.value = 'true'; btn.classList.add('checked'); box.textContent = '✓';
    }
  });

  // Validation
  function validateName(n: string) { return n && n.trim().length >= 2 && !/\d/.test(n); }
  function validatePhone(p: string) { return /^(\+46|0)\d{7,10}$/.test(p.replace(/[-\s]/g, '')); }
  function validatePnr(pnr: string) {
    if (!pnr) return true;
    let c = pnr.replace(/[-\s]/g, '');
    if (c.length === 12) c = c.substring(2);
    if (c.length !== 10 || !/^\d{10}$/.test(c)) return false;
    let sum = 0;
    for (let i = 0; i < 10; i++) { let d = parseInt(c[i]) * (i % 2 === 0 ? 2 : 1); if (d > 9) d -= 9; sum += d; }
    return sum % 10 === 0;
  }

  // Submit
  document.getElementById('intake-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const errEl = document.getElementById('error-msg')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    errEl.style.display = 'none';

    const firstName = (document.getElementById('field-first-name') as HTMLInputElement).value;
    const lastName = (document.getElementById('field-last-name') as HTMLInputElement).value;
    const phone = (document.getElementById('field-phone') as HTMLInputElement).value;
    const pnr = (document.getElementById('field-personal-number') as HTMLInputElement).value;

    if (!validateName(firstName)) { errEl.textContent = 'Ogiltigt förnamn.'; errEl.style.display = 'block'; return; }
    if (!validateName(lastName)) { errEl.textContent = 'Ogiltigt efternamn.'; errEl.style.display = 'block'; return; }
    if (!validatePhone(phone)) { errEl.textContent = 'Ogiltigt telefonnummer (07X-XXX XX XX).'; errEl.style.display = 'block'; return; }
    if (pnr && !validatePnr(pnr)) { errEl.textContent = 'Ogiltigt personnummer.'; errEl.style.display = 'block'; return; }
    if ((document.getElementById('field-gdpr-consent') as HTMLInputElement).value !== 'true') { errEl.textContent = 'Du måste ge ditt samtycke. / ፈቃድዎን መስጠት አለብዎት።'; errEl.style.display = 'block'; return; }

    const membershipType = (document.getElementById('field-membership-type') as HTMLInputElement).value;
    const familyMembers: any[] = [];
    if (membershipType === 'family') {
      document.querySelectorAll('.family-member-row').forEach(row => {
        const fn = (row.querySelector('[data-field="first_name"]') as HTMLInputElement).value.trim();
        const ln = (row.querySelector('[data-field="last_name"]') as HTMLInputElement).value.trim();
        const rel = (row.querySelector('[data-field="relation"]') as HTMLSelectElement).value;
        if (fn && ln) familyMembers.push({ first_name: fn, last_name: ln, personal_number: '', relation: rel });
      });
      if (familyMembers.length === 0) { errEl.textContent = 'Lägg till minst en familjemedlem.'; errEl.style.display = 'block'; return; }
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Skickar...';

    try {
      const resp = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'omit',
        body: JSON.stringify({
          first_name: firstName,
          last_name: lastName,
          phone,
          email: (document.getElementById('field-email') as HTMLInputElement).value,
          personal_number: pnr,
          gdpr_consent: true,
          consent_timestamp: new Date().toISOString(),
          source: (document.getElementById('field-source') as HTMLInputElement).value,
          church_id: (document.getElementById('field-church-id') as HTMLInputElement).value,
          membership_type: membershipType,
          monthly_fee_sek: parseInt((document.getElementById('field-monthly-fee') as HTMLInputElement).value),
          family_members: familyMembers,
        }),
      });

      if (resp.status === 202 || resp.status === 201) {
        document.getElementById('intake-form-card')!.style.display = 'none';
        document.getElementById('success-msg')!.style.display = 'block';
        const fee = parseInt((document.getElementById('field-monthly-fee') as HTMLInputElement).value);
        document.getElementById('success-fee')!.textContent = fee + ' kr';
        const swishNr = churchConfig.swish_number || '';
        const swishLink = document.getElementById('success-swish-link') as HTMLAnchorElement;
        if (swishNr) {
          swishLink.href = `swish://payment?data={"version":1,"payee":{"value":"${swishNr}"},"amount":{"value":${fee}},"message":{"value":"Medlemsavgift","editable":false}}`;
          swishLink.textContent = `Swish — ${fee} kr`;
        }
        const agUrl = churchConfig.autogiro_form_url || '';
        if (agUrl) {
          document.getElementById('autogiro-step')!.style.display = 'block';
          (document.getElementById('autogiro-link') as HTMLAnchorElement).href = agUrl;
        }
        return;
      }

      if (resp.status === 409) throw { userMsg: 'Du är redan registrerad.' };
      if (resp.status === 422) {
        const data = await resp.json();
        const msg = typeof data.detail === 'string' ? data.detail
          : Array.isArray(data.detail) ? data.detail.map((e: any) => e.msg || '').join('. ')
          : 'Kontrollera dina uppgifter.';
        throw { userMsg: msg };
      }
      throw { userMsg: 'Tekniskt fel. Försök igen.' };
    } catch (err: any) {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Skicka ansökan / ማመልከቻ ላክ';
      errEl.textContent = err?.userMsg || 'Kunde inte ansluta till servern.';
      errEl.style.display = 'block';
    }
  });
</script>
